# Copy to .env and adjust before running `docker compose up`.

# ---------- PostgreSQL ----------
DB_NAME=atm
DB_USERNAME=atm
DB_PASSWORD=change-me

# ---------- JWT ----------
# Signing secret - MUST be at least 64 bytes for HS512-grade security.
JWT_SECRET=replace-this-with-a-long-random-secret-of-at-least-64-bytes-please-1234

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173

# ===================================================================
# Mail
# ===================================================================
# By default the platform delivers to the bundled MailHog dev SMTP
# catcher (browse at http://localhost:8025). Mails NEVER leave your
# machine in this mode - it is purely for development / testing.
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@atm.local
MAIL_FROM_NAME=ATM Platform
MAIL_ENABLED=true
MAIL_LOG_TO_CONSOLE=true

# Recipients of "new customer awaiting approval" notifications (comma-separated)
MAIL_ADMIN_RECIPIENTS=admin@atm.local,accountant@atm.local

# -------------------------------------------------------------------
# To send REAL emails to real inboxes via Gmail, comment out the
# MailHog defaults above and uncomment this block.
#
# Pre-requisites:
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an "App password" at
#        https://myaccount.google.com/apppasswords
#      (Google blocks normal-password SMTP auth.)
#   3. Use that 16-character app password as MAIL_PASSWORD below.
# -------------------------------------------------------------------
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.address@gmail.com
# MAIL_PASSWORD=your-16-char-google-app-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# MAIL_FROM=your.address@gmail.com
# MAIL_FROM_NAME=ATM Platform

# ===================================================================
# Demo seed (auto-resets demo passwords on every restart so the
# documented credentials always work). Set DEMO_RESET_PASSWORDS=false
# in any real deployment.
# ===================================================================
DEMO_RESET_PASSWORDS=true
DEMO_DEFAULT_PASSWORD=password
