# Copy to .env and adjust before running `docker compose up`.

# ---------- PostgreSQL ----------
DB_NAME=atm
DB_USERNAME=atm
DB_PASSWORD=change-me

# ---------- JWT ----------
# Signing secret - MUST be at least 64 bytes for HS512-grade security
JWT_SECRET=replace-this-with-a-long-random-secret-of-at-least-64-bytes-please-1234

# ---------- CORS ----------
# Allowed CORS origins for the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173

# ---------- Mail ----------
# Inside the docker-compose network the backend reaches MailHog as "mail".
# The web inbox is at http://localhost:8025
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_ENABLED=true
# Always dump every email body to the application log so you can verify
# the email pipeline end-to-end without ever opening MailHog.
MAIL_LOG_TO_CONSOLE=true

# ---------- Demo seed ----------
# Self-healing demo passwords: every restart re-encodes "password" for all
# seeded demo users so the documented credentials always work.
# Set DEMO_RESET_PASSWORDS=false in any real deployment.
DEMO_RESET_PASSWORDS=true
DEMO_DEFAULT_PASSWORD=password
